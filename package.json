{
  "name": "roonpresence",
  "version": "0.1.0",
  "description": "Command-line MVP for showing Roon HQPlayer playback in Discord Rich Presence.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "setup": "node scripts/setup.js",
    "lastfm:auth": "node scripts/lastfm-auth.js",
    "lastfm:mobile-auth": "node scripts/lastfm-auth.js --mobile",
    "build:launcher": "powershell -ExecutionPolicy Bypass -File scripts/build-launcher.ps1",
    "build:setup": "powershell -ExecutionPolicy Bypass -File scripts/build-setup.ps1",
    "test": "node --test"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "node-pty": "^1.1.0",
    "roon-api": "github:roonlabs/node-roon-api",
    "roon-api-transport": "github:roonlabs/node-roon-api-transport"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=18"
  }
}
